# Copy this file to .env and set your values.
# docker compose will automatically load .env from the same directory.

# ZIP code is now a URL parameter — no env var needed.
# Use: http://host:9798/playlist.m3u?zip=90210

# ── Display ──────────────────────────────────────

# How long each weather slide is displayed before cycling to the next
SLIDE_DURATION=8s

# Output resolution (pixels)
# VIDEO_WIDTH=1280
# VIDEO_HEIGHT=720

# Stream frame rate (fps) — lower values reduce CPU usage
FRAME_RATE=5

# Channel number in the M3U playlist
CHANNEL_NUMBER=1

# ── Weather ──────────────────────────────────────

# NWS API base URL. Defaults to NOAA's public API (no key required, US only).
# Override only if using a caching proxy (e.g., WS4KP in server mode):
#   WEATHER_API_URL=http://ws4kp:8080/api
# WEATHER_API_URL=https://api.weather.gov

# How often to refresh weather data (Go duration: 5m, 10m, 1h, etc.)
WEATHER_REFRESH=20m

# ── Announcements & Trivia ───────────────────────

# ANNOUNCEMENT_DURATION=10s
# ANNOUNCEMENT_INTERVAL=2
# TRIVIA_DURATION=20s
# TRIVIA_INTERVAL=3

# ── Trivia API ───────────────────────────────────

# Open Trivia Database settings
# TRIVIA_API=true
# TRIVIA_API_AMOUNT=25
# TRIVIA_API_CATEGORY=9
# TRIVIA_API_DIFFICULTY=
# TRIVIA_API_REFRESH=24h
# TRIVIA_BUILTIN=false

# ── Music ────────────────────────────────────────

# Path to background music directory (local audio files: mp3, flac, ogg, etc.)
# When the directory is empty or missing, MUSIC_STREAM_URL is used instead.
# MUSIC_DIR=/music

# HTTP/Icecast stream URL for background audio.
# Used automatically when MUSIC_DIR has no files.
# Default: SomaFM Secret Agent (lounge/spy jazz, no ads)
# Set to empty string to use silence instead of a stream.
# MUSIC_STREAM_URL=https://ice1.somafm.com/secretagent-128-mp3

# ── Video Encoding ───────────────────────────────

# VBV max bitrate — smooths output so IPTV clients don't buffer underrun
# during static slides. Set to empty string to disable (pure VBR).
# VIDEO_MAXRATE=1500k

# ── Streaming ────────────────────────────────────

# HLS streaming tuning (defaults work well for most setups)
# HLS_SEGMENT_DURATION=3s
# HLS_PLAYLIST_SIZE=3
# HLS_RING_SIZE=5

# ── Radar & Satellite ────────────────────────────

# RADAR_FRAMES=4    # animation frames (radar & satellite)
# RADAR_RADIUS=120  # bounding box radius in miles (radar & satellite)

# ── RTSP / RTMP / WebRTC ────────────────────────

# Requires docker-compose.rtsp.yml overlay
# ZIP code to expose via RTSP at rtsp://host:8554/weather
# RTSP_ZIP=90210
